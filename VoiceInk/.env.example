# ---- Server (server/index.js) ----
# WebSocket port (default 8080)
WS_PORT=8080

# Comma-separated allowed origins for WebSocket connections.
# Leave empty for dev (allows all). Set for production security.
# Example: https://<username>.github.io
ALLOWED_ORIGINS=

# iFlytek credentials — server-managed, takes priority over client-sent keys
IFLYTEK_APP_ID=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=

# Deepgram credentials — server-managed
DEEPGRAM_API_KEY=

# Proxy for outbound connections (e.g. Deepgram)
# HTTPS_PROXY=http://127.0.0.1:7890

# ---- Frontend (Vite build-time) ----
# Production WebSocket URL (wss://your-api-domain.example.com)
VITE_WS_URL=

# Base path for GitHub Pages: /<repo-name>/ or / for custom domain
# In CI, set this as a GitHub Actions Variable (VITE_BASE_PATH)
# VITE_BASE_PATH=/voiceink/

# Optional: override dev WebSocket host (defaults to window.location.hostname)
# VITE_DEV_WS_HOST=192.168.1.100

# ---- Deploy helpers ----
# Public frontend URL for qr:prod script
# GitHub Pages default: https://<username>.github.io/<repo-name>
# VOICEINK_APP_URL=https://<username>.github.io/voiceink
